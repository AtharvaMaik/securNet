{
  "uid": "security-service-health",
  "title": "Service Health",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-30m", "to": "now" },
  "refresh": "15s",
  "panels": [
    {
      "type": "stat",
      "title": "Service Up",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [{ "expr": "up{job=~\"api-gateway|auth-service|vault-service|scan-service\"}", "legendFormat": "{{job}}" }]
    },
    {
      "type": "timeseries",
      "title": "Requests / sec",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [{ "expr": "{__name__=\"service:request_rate5m\"}", "legendFormat": "{{service}}" }]
    },
    {
      "type": "timeseries",
      "title": "5xx Rate",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [{ "expr": "{__name__=\"service:http_5xx_rate5m\"}", "legendFormat": "{{service}}" }]
    },
    {
      "type": "timeseries",
      "title": "p95 Latency",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [{ "expr": "max by (service) ({__name__=\"service:latency_p95_5m\"})", "legendFormat": "{{service}}" }]
    },
    {
      "type": "timeseries",
      "title": "Dependency Health",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [{ "expr": "security_platform_dependency_health", "legendFormat": "{{service}} :: {{dependency}}" }]
    }
  ]
}
