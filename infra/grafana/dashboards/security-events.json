{
  "uid": "security-events",
  "title": "Security Events",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-30m", "to": "now" },
  "refresh": "15s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Failed Logins",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [{ "expr": "{__name__=\"service:failed_login_rate5m\"}", "legendFormat": "{{service}}" }]
    },
    {
      "type": "timeseries",
      "title": "Token Validation Failures",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [{ "expr": "{__name__=\"service:token_validation_failure_rate5m\"}", "legendFormat": "{{service}}" }]
    },
    {
      "type": "timeseries",
      "title": "Burst Traffic",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [{ "expr": "{__name__=\"service:burst_traffic_rate5m\"}", "legendFormat": "{{service}}" }]
    },
    {
      "type": "timeseries",
      "title": "Rate-Limited Requests",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [{ "expr": "{__name__=\"service:rate_limited_rate5m\"}", "legendFormat": "{{service}}" }]
    },
    {
      "type": "timeseries",
      "title": "Secrets Access Errors",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [{ "expr": "{__name__=\"service:secret_access_error_rate5m\"}", "legendFormat": "{{service}}" }]
    },
    {
      "type": "timeseries",
      "title": "Scan Backlog",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [{ "expr": "security_platform_queue_depth{queue_name=\"scan-jobs\"}", "legendFormat": "{{service}}" }]
    }
  ]
}
